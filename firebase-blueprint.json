      "properties": {
        "nomEtablissement": { "type": "string" },
        "devise": { "type": "string" },
        "couleurPrimaire": { "type": "string" },
        "couleurSecondaire": { "type": "string" },
        "signatureDirecteur": { "type": "string" },
        "signatureResponsable": { "type": "string" },
        "format": { "type": "string" }
