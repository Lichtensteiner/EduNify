      "title": "Finance Settings",
      "description": "Financial configuration and starting balances for establishments",
      "type": "object",
      "properties": {
        "establishmentId": { "type": "string" },
        "initialCash": { "type": "number" },
        "initialBank": { "type": "number" },
        "initialMomo": { "type": "number" },
        "defaultRequiredFee": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
