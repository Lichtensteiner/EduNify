      "required": ["establishmentId"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "users", "description": "User documents" },
    "/attendance/{attId}": { "schema": "attendance", "description": "Daily summaries" },
    "/attendance_logs/{logId}": { "schema": "attendance_logs", "description": "Scans logs" },
    "/clubs/{clubId}": { "schema": "clubs", "description": "Club documents" },
    "/grades/{gradeId}": { "schema": "grades", "description": "Grade entries" },
    "/sanctions/{sanctionId}": { "schema": "sanctions", "description": "Discipline entries" },
    "/homework/{homeworkId}": { "schema": "homework", "description": "Homework assignments" },
    "/preparations/{prepId}": { "schema": "preparations", "description": "Lesson plans and courses" },
    "/notifications/{notifId}": { "schema": "notifications", "description": "User notifications" },
    "/user_sessions/{sessionId}": { "schema": "user_sessions", "description": "Real-time user sessions" },
    "/teacher_planning/{planId}": { "schema": "teacher_planning", "description": "Daily planning for teachers" },
    "/strategic_optimizations/{optId}": { "schema": "strategic_optimizations", "description": "AI-guided optimizations list and structural logs." },
    "/role_responsibilities/{respId}": { "schema": "role_responsibilities", "description": "Custom roles access and missions." },
    "/maternelle_siestas/{siestaId}": { "schema": "maternelle_siestas", "description": "Real-time sleep logs for toddlers." },
    "/maternelle_transmissions/{transmissionId}": { "schema": "maternelle_transmissions", "description": "Liaison notes and daily transmissions for nursery parents." },
    "/resp_reading_progress/{rpId}": { "schema": "resp_reading_progress", "description": "Reading progress tracking for primary challenge." },
    "/resp_field_trips/{ftId}": { "schema": "resp_field_trips", "description": "Authorized field trips records." },
